client_body_buffer_size 1m;  # 增加缓冲区大小
large_client_header_buffers 4 1m;  # 增加缓冲区大小和数量
client_max_body_size 80m;  # 设置全局最大上传文件大小为 50 MB
server {
    listen 443 ssl;

    ssl_certificate /home/ubuntu/ssl/oldbai.top.pem;
    ssl_certificate_key /home/ubuntu/ssl/oldbai.top.key;

    # Add index.php to the list if you are using PHP
    index index.html index.htm index.nginx-debian.html;

    server_name oldbai.top;

    location ^~ /gateway/ {
        proxy_pass http://localhost:20000/gateway/;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forward-For $remote_addr;
    }

    location ^~ /frpgateway/ {
        proxy_pass http://localhost:9848/gateway/;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forward-For $remote_addr;
    }

    location ^~ /oss/ {
        proxy_pass http://localhost:20011/lbsingle/;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forward-For $remote_addr;
    }


    location ^~ /ws/ {
        proxy_pass http://localhost:20011/;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forward-For $remote_addr;
        proxy_http_version 1.1;  # 必须设置为1.1以支持WebSocket
        proxy_set_header Upgrade $http_upgrade;  # 设置Upgrade头
        proxy_set_header Connection "upgrade";   # 设置Connection头
    }

    location /admin {  # Vue应用的访问路径
        # root /home/ubuntu/web/dist;
        alias /home/ubuntu/web/dist;
	    index index.html index.htm;
        try_files $uri $uri/ /admin/index.html =404;
    }

    location /blog {
    	root /home/ubuntu/blog;
	    index index.html index.htm;
        try_files $uri $uri/ /index.html =404;
    }
}
