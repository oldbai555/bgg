type (
	// 聊天消息
	ChatMessageItem {
		id           uint64 `json:"id"`
		chatId       uint64 `json:"chatId"` // 聊天ID（关联chat表）
		fromUserId   uint64 `json:"fromUserId"`
		fromUserName string `json:"fromUserName"`
		content      string `json:"content"`
		messageType  int64  `json:"messageType"`
		status       int64  `json:"status"`
		createdAt    int64  `json:"createdAt"` // 创建时间(秒级时间戳)
	}
	// 消息列表请求
	ChatMessageListReq {
		page     int64  `json:"page,optional" form:"page,optional"`
		pageSize int64  `json:"pageSize,optional" form:"pageSize,optional"`
		chatId   uint64 `json:"chatId,optional" form:"chatId,optional"` // 聊天ID（关联chat表）
	}
	// 消息列表响应
	ChatMessageListResp {
		total int64             `json:"total"`
		list  []ChatMessageItem `json:"list"`
	}
	// 发送消息请求
	ChatMessageSendReq {
		chatId      uint64 `json:"chatId"` // 聊天ID（关联chat表）
		content     string `json:"content"` // 消息内容
		messageType int64  `json:"messageType,optional"` // 消息类型：1文本，2图片，3文件
	}
	// 发送消息响应
	ChatMessageSendResp {
		id uint64 `json:"id"`
	}
	// 删除聊天消息请求
	ChatMessageDeleteReq {
		id uint64 `json:"id"`
	}
	// 聊天列表请求
	ChatListReq  {}
	// 聊天列表响应
	ChatItem {
		chatId         uint64   `json:"chatId"`
		name           string   `json:"name"` // 聊天名称（群组名称，私聊显示对方昵称或用户名）
		chatType       int64    `json:"type"` // 聊天类型：1私聊，2群组
		avatar         string   `json:"avatar,optional"` // 头像URL
		description    string   `json:"description,optional"` // 描述（群组描述）
		userId         uint64   `json:"userId,optional"` // 私聊时的对方用户ID（群组为0）
		username       string   `json:"username,optional"` // 私聊时的对方用户名
		nickname       string   `json:"nickname,optional"` // 私聊时的对方昵称
		departmentName string   `json:"departmentName,optional"` // 私聊时的对方部门名称
		roleNames      []string `json:"roleNames,optional"` // 私聊时的对方角色名称列表
		unreadCount    int64    `json:"unreadCount,optional"` // 未读消息数
		lastMessage    string   `json:"lastMessage,optional"` // 最后一条消息内容
		lastMessageAt  int64    `json:"lastMessageAt,optional"` // 最后一条消息时间(秒级时间戳)
	}
	ChatListResp {
		list []ChatItem `json:"list"`
	}
	// 群组列表请求
	ChatGroupListReq {
		page     int64  `form:"page,optional"` // 页码
		pageSize int64  `form:"pageSize,optional"` // 每页数量
		name     string `form:"name,optional"` // 群组名称（模糊搜索）
	}
	// 群组列表项
	ChatGroupItem {
		id          uint64 `json:"id"` // 群组ID
		name        string `json:"name"` // 群组名称
		avatar      string `json:"avatar,optional"` // 群组头像
		description string `json:"description,optional"` // 群组描述
		createdBy   uint64 `json:"createdBy"` // 创建人ID
		createdAt   int64  `json:"createdAt"` // 创建时间(秒级时间戳)
		memberCount int64  `json:"memberCount"` // 成员数量
	}
	// 群组列表响应
	ChatGroupListResp {
		total int64           `json:"total"` // 总数
		list  []ChatGroupItem `json:"list"` // 群组列表
	}
	// 群组创建请求
	ChatGroupCreateReq {
		name        string   `json:"name"` // 群组名称
		avatar      string   `json:"avatar,optional"` // 群组头像
		description string   `json:"description,optional"` // 群组描述
		userIds     []uint64 `json:"userIds,optional"` // 初始成员用户ID列表（不包括创建人）
	}
	// 群组更新请求
	ChatGroupUpdateReq {
		id          uint64 `json:"id"` // 群组ID
		name        string `json:"name,optional"` // 群组名称
		avatar      string `json:"avatar,optional"` // 群组头像
		description string `json:"description,optional"` // 群组描述
	}
	// 群组删除请求
	ChatGroupDeleteReq {
		id uint64 `json:"id"` // 群组ID
	}
	// 群组详情请求
	ChatGroupDetailReq {
		id uint64 `path:"id"` // 群组ID
	}
	// 群组详情响应
	ChatGroupDetailResp {
		id          uint64                `json:"id"`
		name        string                `json:"name"`
		avatar      string                `json:"avatar,optional"`
		description string                `json:"description,optional"`
		createdBy   uint64                `json:"createdBy"`
		createdAt   int64                 `json:"createdAt"`
		memberCount int64                 `json:"memberCount"` // 成员数量
		members     []ChatGroupMemberItem `json:"members,optional"` // 成员列表
	}
	// 群组成员项
	ChatGroupMemberItem {
		userId         uint64   `json:"userId"`
		username       string   `json:"username"`
		nickname       string   `json:"nickname,optional"`
		avatar         string   `json:"avatar,optional"`
		departmentName string   `json:"departmentName,optional"`
		roleNames      []string `json:"roleNames,optional"`
		joinedAt       int64    `json:"joinedAt"` // 加入时间
	}
	// 群组成员添加请求
	ChatGroupMemberAddReq {
		chatId  uint64   `json:"chatId"` // 群组ID
		userIds []uint64 `json:"userIds"` // 要添加的用户ID列表
	}
	// 群组成员移除请求
	ChatGroupMemberRemoveReq {
		chatId uint64 `json:"chatId"` // 群组ID
		userId uint64 `json:"userId"` // 要移除的用户ID
	}
	// 群组成员列表请求
	ChatGroupMemberListReq {
		id uint64 `path:"id"` // 群组ID
	}
	// 群组成员列表响应
	ChatGroupMemberListResp {
		list []ChatGroupMemberItem `json:"list"`
	}
)

