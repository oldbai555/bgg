# docker-compose.dev-mixed.yml 的环境变量模板。
# 复制为 .env（同目录，与 docker-compose.dev-mixed.yml 平级），填入真实值。
# .env 不提交仓库（见 .gitignore），只保存在部署目标机器本地。

# openssl rand -base64 48 生成，两个必须不同
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# 宿主机本地 Redis 密码（/etc/work/redis.json 里的 password）
HOST_REDIS_PASSWORD=

# 外部托管 MySQL 完整 DSN（sqlpub 等共享托管账号通常只有 1 个库，
# task/sdk/chat/content 复用同一个库，见 db/init-tables-into-oldbai.sql）
# 格式: <user>:<password>@tcp(<host>:<port>)/<database>?charset=utf8mb4&parseTime=true&loc=Local
IAM_MYSQL_DSN=

# 飞书自建应用扫码登录（开放平台后台的 App ID/Secret，与本机开发环境一致；
# RedirectUri 必须在开放平台「安全设置-重定向URL」白名单里，且与部署域名匹配，
# 不能照抄本机 localhost 的值）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=
